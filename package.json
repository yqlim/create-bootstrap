{
  "name": "create-bootstrap",
  "version": "1.0.4",
  "description": "Create a new Node.js project with opinionated bootstrap.",
  "type": "module",
  "bin": {
    "create-bootstrap": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint --cache --fix --max-warnings 0 .",
    "lint-staged": "lint-staged",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "release": "pnpm build && npm publish",
    "spell-check": "cspell lint '**'",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:templates": "for dir in ./templates/*; do if [ -d \"$dir\" ]; then (cd \"$dir\" && pnpm install && pnpm test) fi done",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cspell/cspell-types": "^9.4.0",
    "@cspell/eslint-plugin": "^9.4.0",
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@inquirer/testing": "^2.1.53",
    "@tsconfig/node24": "^24.0.3",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.10.3",
    "@types/yargs": "^17.0.35",
    "cspell": "^9.4.0",
    "eslint": "^9.39.2",
    "eslint-plugin-only-warn": "^1.1.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "micromatch": "^4.0.8",
    "prettier": "~3.6.2",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-sh": "^0.18.0",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501",
  "author": "yqlim <23203360+yqlim@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yqlim/create-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/yqlim/create-bootstrap/issues"
  },
  "homepage": "https://github.com/yqlim/create-bootstrap#readme",
  "keywords": [
    "setup",
    "bootstrap",
    "create",
    "new",
    "project",
    "wizard",
    "node"
  ]
}
