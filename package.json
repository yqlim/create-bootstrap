{
  "name": "create-bootstrap",
  "version": "1.0.6",
  "description": "Create a new Node.js project with opinionated bootstrap.",
  "type": "module",
  "bin": {
    "create-bootstrap": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint --cache --fix --max-warnings 0 .",
    "lint-staged": "lint-staged",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "release": "pnpm build && npm publish",
    "spell-check": "cspell lint '**'",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:templates": "for dir in ./templates/*; do if [ -d \"$dir\" ]; then (cd \"$dir\" && pnpm install && pnpm test) fi done",
    "type-check": "tsc --noEmit",
    "update:templates": "for template in templates/*; do (cd $template && corepack up && pnpm update) done"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cspell/cspell-types": "^9.7.0",
    "@cspell/eslint-plugin": "^9.7.0",
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@inquirer/testing": "^2.1.53",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.12.0",
    "@types/yargs": "^17.0.35",
    "cspell": "^9.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-only-warn": "^1.2.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "micromatch": "^4.0.8",
    "prettier": "~3.6.2",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-sh": "^0.18.0",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "author": "yqlim <23203360+yqlim@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yqlim/create-bootstrap.git"
  },
  "bugs": {
    "url": "https://github.com/yqlim/create-bootstrap/issues"
  },
  "homepage": "https://github.com/yqlim/create-bootstrap#readme",
  "keywords": [
    "setup",
    "bootstrap",
    "create",
    "new",
    "project",
    "wizard",
    "node"
  ]
}
