{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": [
    "@internals/tsconfig/base.json",
    "@internals/tsconfig/platform.server.json"
  ],
  "compilerOptions": {
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "noEmit": true,
    "verbatimModuleSyntax": true
  },
  "exclude": ["apps", "internals", "node_modules", "packages"]
}
