{
  "name": "@packages/ui",
  "version": "0.0.0",
  "type": "module",
  "description": "A shared UI component library for this project.",
  "private": true,
  "exports": {
    "./*": "./dist/*"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "npm run build -- --watch",
    "format": "prettier --write .",
    "test": "npm run test:type",
    "test:lint": "eslint --max-warnings 0 --no-warn-ignored .",
    "test:type": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "^9.8.0",
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@internals/eslint-config": "workspace:*",
    "@internals/lint-staged-config": "workspace:*",
    "@internals/prettier-config": "workspace:*",
    "@internals/tsconfig": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-only-warn": "^1.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-pkg": "^0.21.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
