{
  "name": "@internals/lint-staged-config",
  "version": "0.0.0",
  "type": "module",
  "description": "A shared lint-staged configuration for this project.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "npm run build -- --watch",
    "test": "npm run test:type",
    "test:lint": "eslint --max-warnings 0 --no-warn-ignored .",
    "test:type": "tsc --noEmit"
  },
  "peerDependencies": {
    "lint-staged": "^15.4.3"
  },
  "devDependencies": {
    "@cspell/eslint-plugin": "^9.8.0",
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@internals/eslint-config": "workspace:*",
    "@internals/prettier-config": "workspace:*",
    "@internals/tsconfig": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "eslint-plugin-only-warn": "^1.2.1",
    "globals": "^17.5.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-pkg": "^0.21.2",
    "prettier-plugin-sh": "^0.18.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
